IGDB_CLIENT_ID=your_igdb_client_id
IGDB_CLIENT_SECRET=your_igdb_client_secret

# Required by the new backend/ (FastAPI) once you use anything auth-related — login will
# fail loudly with a clear error if this is unset, rather than falling back to an
# insecure default. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Optional. If unset, backend/ falls back to an in-process cache (fine for one instance).
REDIS_URL=

# Optional. If unset, backend/ defaults to a local SQLite file under backend/db/.
DATABASE_URL=

# Optional, JSON array of allowed origins. Defaults to ["http://localhost:3000"] (the Vite
# dev server) — only needed in production if frontend and backend are served from
# different origins, which isn't the normal deployment shape (FastAPI serves the built
# frontend itself, same-origin, post-cutover — see docs/architecture/02-roadmap.md M5).
# CORS_ORIGINS=["https://your-domain.example"]

# Optional, docker-compose.yml only. Which host port to publish the app on. Defaults to 8000.
# APP_PORT=8000
