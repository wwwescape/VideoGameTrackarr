{
    "name": "videogametrackarr",
    "version": "1.0.0",
    "description": "A self-hosted web application to track your video game collection",
    "private": true,
    "workspaces": [
        "frontend"
    ],
    "scripts": {
        "start": "npm run start -w frontend",
        "build": "npm run build -w frontend",
        "preview": "npm run preview -w frontend",
        "lint": "npm run lint -w frontend && npm run lint:e2e",
        "lint:e2e": "eslint e2e playwright.config.ts --ext .ts",
        "typecheck": "npm run typecheck -w frontend && tsc -p tsconfig.json --noEmit",
        "test": "npm run test -w frontend",
        "test:coverage": "npm run test:coverage -w frontend",
        "test:e2e": "playwright test",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "devDependencies": {
        "@playwright/test": "^1.61.0",
        "@types/node": "^20.14.0",
        "@typescript-eslint/eslint-plugin": "^7.18.0",
        "@typescript-eslint/parser": "^7.18.0",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "prettier": "^3.2.5",
        "typescript": "^5.5.4"
    }
}
